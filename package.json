{
    "name": "tecmo-super-bowl",
    "version": "1.0.0",
    "description": "Run automated Tecmo Super Bowl seasons and collect stats",
    "main": "bin/cli.js",
    "type": "module",
    "scripts": {
        "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "lint:js": "node node_modules/eslint/bin/eslint.js .",
        "lint:lua": "if command -v luacheck >/dev/null 2>&1; then luacheck src/emulator/lua; elif [ -x \"$HOME/.luarocks/bin/luacheck\" ]; then \"$HOME/.luarocks/bin/luacheck\" src/emulator/lua; else echo 'luacheck not found. Install with: luarocks --local install luacheck'; exit 1; fi",
        "lint:all": "npm run lint:js && npm run lint:lua",
        "format:js": "prettier --write \"**/*.{js,mjs,cjs}\"",
        "format:js:check": "prettier --check \"**/*.{js,mjs,cjs}\"",
        "format:lua": "stylua src/emulator/lua",
        "format:lua:check": "stylua --check src/emulator/lua",
        "format:all": "npm run format:js && npm run format:lua",
        "format:all:check": "npm run format:js:check && npm run format:lua:check",
        "simulate": "node scripts/run-season.js",
        "simulate:multi": "node scripts/run-multi-season.js",
        "db:migrate": "knex migrate:latest",
        "db:rollback": "knex migrate:rollback",
        "db:seed": "node scripts/seed.js",
        "db:backup": "cp -a data/stats.db data/backup/stats.db.$(date +\"%m%d%Y.%H%M%S\")",
        "db:refresh-injury-stats": "node scripts/refresh-injury-stats.js",
        "extract-rom": "node scripts/extract-rom-data.js"
    },
    "dependencies": {
        "better-sqlite3": "^12.8.0",
        "knex": "^3.1.0",
        "minimist": "^1.2.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "@johnnymorganz/stylua-bin": "^2.4.0",
        "eslint": "^10.0.3",
        "globals": "^16.0.0",
        "jest": "^29.7.0",
        "prettier": "^3.6.2"
    }
}
