{
    "name": "tecmo-super-bowl",
    "version": "1.0.0",
    "description": "Run automated Tecmo Super Bowl seasons and collect stats",
    "main": "bin/cli.js",
    "type": "module",
    "scripts": {
        "test": "NODE_OPTIONS=--experimental-vm-modules jest",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
        "lint": "node node_modules/eslint/bin/eslint.js .",
        "lint:fix": "node node_modules/eslint/bin/eslint.js . --fix",
        "simulate": "node bin/cli.js simulate",
        "db:migrate": "knex migrate:latest",
        "db:rollback": "knex migrate:rollback",
        "db:seed": "node scripts/seed.js",
        "extract-rom": "node scripts/extract-rom-data.js"
    },
    "dependencies": {
        "better-sqlite3": "^12.8.0",
        "knex": "^3.1.0",
        "minimist": "^1.2.8"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.10.0",
        "eslint": "^10.0.3",
        "jest": "^29.7.0"
    }
}
